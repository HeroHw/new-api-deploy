# 镜像配置（必填）
ACR_REGISTRY=your-registry.azurecr.io
APP_NAME=new-api-test
IMAGE_TAG=latest

# 容器名称配置
CONTAINER_NAME=app

# 网络配置
NETWORK_NAME=deploy-network

# 端口配置
APP_PORT=3000

# 内核参数与文件描述符限制（对应 docker-compose ulimits / sysctls）
ULIMIT_NOFILE_SOFT=1024
ULIMIT_NOFILE_HARD=1024
IP_LOCAL_PORT_RANGE_START=32768
IP_LOCAL_PORT_RANGE_END=60999
TCP_TW_REUSE=2
TCP_FIN_TIMEOUT=60

# 运行环境。production 启用生产模式（等同于 GIN_MODE=release），关闭调试输出
APP_ENV=production

# MySQL 连接字符串，格式：用户:密码@tcp(主机:端口)/库名
SQL_DSN=root:123456@tcp(127.0.0.1:3306)/new-api

# 连接池中最大空闲连接数
SQL_MAX_IDLE_CONNS=100

# 最大并发打开连接数，应根据 MySQL max_connections 设置
SQL_MAX_OPEN_CONNS=1000

# 用于加密存储在 Redis 中的敏感数据（如渠道 Key），多机部署时必须一致
CRYPTO_SECRET=g8TqFoX23uVEVRFk5t

# JWT/Session 签名密钥，多机部署时必须一致，否则不同节点的登录态互不认可
SESSION_SECRET=v40O7Auy6CsOgO9c4I

# 时区设置，影响日志时间戳和定时任务的时间基准
TZ=Asia/Shanghai

# 多机部署时从节点取消注释下面的（NODE_TYPE）
# NODE_TYPE=slave

# 启用错误日志记录到数据库/文件
ERROR_LOG_ENABLED=true

# 关闭详细调试日志
DEBUG=false

# 中继请求总超时时间（秒），设为 1 小时，适合长时间推理任务
RELAY_TIMEOUT=3600

# 流式响应超时（秒），两次 SSE 数据包之间的最大等待时间
STREAMING_TIMEOUT=3600

# 强制在流式请求中注入 stream_options: {include_usage: true}，确保返回 token 用量
FORCE_STREAM_OPTION=true

# 首次启动时自动生成默认 API 令牌
GENERATE_DEFAULT_TOKEN=true

# Gemini 视觉请求中允许的最大图片数量
GEMINI_VISION_MAX_IMAGE_NUM=3000

# 如果设置了，会针对这些模型进行按次收费
# TASK_PRICE_PATCH=sora-2-pro,sora-2

# Redis 连接池大小
REDIS_POOL_SIZE=10

# Redis 连接地址，设置后自动启用内存缓存
REDIS_CONN_STRING=redis://127.0.0.1:6379/0

# 如果设置了REDIS_CONN_STRING，则无需手动设置（MEMORY_CACHE_ENABLED）
# MEMORY_CACHE_ENABLED=true

# 每隔 n 秒从数据库同步渠道/令牌数据到内存缓存
SYNC_FREQUENCY=60

# 每隔 30 秒更新渠道状态（余额、可用性等）
CHANNEL_UPDATE_FREQUENCY=30

# 启用批量更新，减少数据库写入频率
BATCH_UPDATE_ENABLED=true

# 批量更新间隔，每 5 秒将累积的配额消耗批量写入数据库
BATCH_UPDATE_INTERVAL=5

# 关闭全局 API 速率限制
GLOBAL_API_RATE_LIMIT=false

# 同上。部分版本使用此变量名
GLOBAL_API_RATE_LIMIT_ENABLE=false

# 关闭全局 Web 页面速率限制
GLOBAL_WEB_RATE_LIMIT=false

# 同上。部分版本使用此变量名
GLOBAL_WEB_RATE_LIMIT_ENABLE=false